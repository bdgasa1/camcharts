---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout>

  <!-- Migration notice -->
  <div class="migration-banner">
    This site is moving to
    <a href="https://camentis.ai" target="_blank" rel="noopener">camentis.ai</a>
    in September 2026.
  </div>

  <Header />

  <main>

    <!-- ═══════════════════════════════════════
         HERO  (existing component — keep images)
    ══════════════════════════════════════════ -->
    <Hero height="60vh" />

    <!-- ═══════════════════════════════════════
         TRACTION BAR
    ══════════════════════════════════════════ -->
    <section class="traction">
      <div class="container">
        <div class="traction-grid">

          <div class="traction-item">
            <span class="t-figure">£61,600</span>
            <span class="t-label">
              Technology Investment Fund, <br>University of Cambridge
            </span>
          </div>

          <div class="traction-item">
            <span class="t-figure">2&times; Winner</span>
            <span class="t-label">
              Best Collaborative Project &amp; Winner of Winners,
              Industrial Construction Awards 2026. Shortlisted: Digital Innovation.
            </span>
          </div>

          <div class="traction-item">
            <span class="t-figure">25+</span>
            <span class="t-label">
              Projects validated across major UK contractors
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         WHAT WE DO
    ══════════════════════════════════════════ -->
    <section class="what-we-do">
      <div class="container">
        <div class="two-col">

          <h2>What we do</h2>

          <div class="body-col">
            <p>
              Construction data exists on every project, but it sits in
              disconnected silos (planning tools, site diaries, delivery
              records, visual capture systems) with no integration layer
              connecting them. By the time a slowdown appears in the weekly
              report, the window to intervene has closed.
            </p>
            <p>
              Camentis connects all of those streams into one consistent,
              standardised view of productivity. The platform is built with over five years of empirical research at the Laing
              O'Rourke Centre for Construction Engineering and Technology,
              University of Cambridge, and validated through pilot deployments
              with Tier 1 and Tier 2 UK contractors.
            </p>
            <a
              href="https://camentis.ai"
              target="_blank"
              rel="noopener"
              class="btn"
            >
              Open platform ↗
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         FOUNDERS
    ══════════════════════════════════════════ -->
    <section class="founders">
      <div class="container">
        <h2 class="section-heading">Our founders</h2>
        <div class="founders-grid">

          <!-- Ashan -->
          <div class="founder-card">
            <h3>Dr Ashan Asmone</h3>
            <span class="role">Co-Founder/CEO</span>
            <p>
              Research Associate, Laing O'Rourke Centre for Construction
              Engineering and Technology, University of Cambridge. 15+ years
              across construction delivery, facilities management, and built
              environment research. 
            </p>
            <p class="qual"></p>
            <a
              href="https://www.linkedin.com/in/ashan-asmone/"
              target="_blank"
              rel="noopener"
              class="linkedin-link"
            >
              LinkedIn ↗
            </a>
          </div>

          <!-- Danny -->
          <div class="founder-card">
            <h3>Dr Danny Murguia</h3>
            <span class="role">Co-Founder/CTO</span>
            <p>
              Assistant Research Professor, Laing O'Rourke Centre for
              Construction Engineering and Technology, University of Cambridge.
              20 years of construction engineering experience. Leads digital
              automation research at the LOR Centre. 
            </p>
            <a
              href="https://www.linkedin.com/in/dannymurguia/"
              target="_blank"
              rel="noopener"
              class="linkedin-link"
            >
              LinkedIn ↗
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         CONTACT
    ══════════════════════════════════════════ -->
    <section class="contact" id="contact">
      <div class="container">
        <div class="contact-grid">

          <div class="contact-intro">
            <h2>Work with us</h2>
            <p>
              We are onboarding pilot partners for 2026–2027. If you are a
              contractor, developer, or infrastructure client and want to
              explore what consistent productivity measurement looks like on
              your project, get in touch.
            </p>
            <a href="mailto:info@camconiq.com" class="email-link">
              info@camconiq.com
            </a>
          </div>

          <!--
            FORM: uses Formspree for static-site email delivery.
            Steps:
              1. Sign up free at https://formspree.io
              2. Create a form → copy your endpoint code
              3. Replace "REPLACE_WITH_YOUR_CODE" below with that code
              e.g. action="https://formspree.io/f/xbjnkqpo"
          -->
          <form
            class="contact-form"
            action="https://formspree.io/f/REPLACE_WITH_YOUR_CODE"
            method="POST"
          >
            <input
              type="text"
              name="name"
              placeholder="Name"
              required
            />
            <input
              type="email"
              name="email"
              placeholder="Email"
              required
            />
            <textarea
              name="message"
              placeholder="Message"
              rows="5"
              required
            ></textarea>
            <button type="submit" class="btn">Send message</button>
          </form>

        </div>
      </div>
    </section>

  </main>

  <Footer />

</BaseLayout>

<style>
  /* ─── MIGRATION BANNER ───────────────────── */
  .migration-banner {
    background: #fff3e0;
    border-bottom: 1px solid #ffd0a0;
    text-align: center;
    padding: 9px 24px;
    font-size: 13px;
    color: #555;
    font-family: "Poppins", sans-serif;
  }
  .migration-banner a {
    color: #E9560D;
    font-weight: 600;
    text-decoration: none;
  }
  .migration-banner a:hover { text-decoration: underline; }

  /* ─── SHARED ─────────────────────────────── */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .btn {
    display: inline-block;
    padding: 12px 28px;
    background: #333F48;
    color: #fff;
    font-family: "Poppins", sans-serif;
    font-weight: 600;
    font-size: 15px;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .btn:hover { background: #E9560D; color: #fff; }

  /* ─── TRACTION BAR ───────────────────────── */
  .traction {
    background: #f5f5f5;
    padding: 52px 0;
    border-bottom: 1px solid #eee;
  }

  .traction-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .traction-item {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .t-figure {
    font-size: 28px;
    font-weight: 600;
    color: #E9560D;
    line-height: 1.2;
    font-family: "Poppins", sans-serif;
  }

  .t-label {
    font-size: 14px;
    color: #555;
    line-height: 1.55;
  }

  /* ─── WHAT WE DO ─────────────────────────── */
  .what-we-do {
    padding: 88px 0;
    background: #fff;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 48px;
    align-items: start;
  }

  .two-col h2 {
    font-size: 48px;
    font-weight: 300;
    color: #333F48;
    line-height: 1.15;
    margin: 0;
    padding-top: 6px;
  }

  .body-col p {
    font-size: 18px;
    line-height: 1.75;
    color: #333F48;
    margin-bottom: 20px;
  }

  .body-col a:not(.btn) {
    color: #E9560D;
    font-weight: 500;
  }

  .body-col .btn { margin-top: 8px; }

  /* ─── FOUNDERS ───────────────────────────── */
  .founders {
    background: #f5f5f5;
    padding: 88px 0;
  }

  .section-heading {
    font-size: 36px;
    font-weight: 300;
    color: #333F48;
    margin: 0 0 40px 0;
  }

  .founders-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }

  .founder-card {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    padding: 32px;
    display: flex;
    flex-direction: column;
  }

  .founder-card h3 {
    font-size: 20px;
    font-weight: 600;
    color: #333F48;
    margin: 0 0 6px 0;
  }

  .role {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    color: #E9560D;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: 18px;
  }

  .founder-card p {
    font-size: 15px;
    line-height: 1.7;
    color: #555;
    margin-bottom: 12px;
    flex-grow: 1;
  }

  .qual {
    font-size: 13px !important;
    color: #888 !important;
    flex-grow: 0 !important;
  }

  .linkedin-link {
    display: inline-block;
    font-size: 14px;
    font-weight: 600;
    color: #333F48;
    text-decoration: none;
    margin-top: 12px;
    transition: color 0.2s;
  }
  .linkedin-link:hover { color: #E9560D; }

  /* ─── CONTACT ────────────────────────────── */
  .contact {
    padding: 88px 0;
    background: #fff;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: start;
  }

  .contact-intro h2 {
    font-size: 36px;
    font-weight: 300;
    color: #333F48;
    margin: 0 0 20px 0;
  }

  .contact-intro p {
    font-size: 16px;
    line-height: 1.75;
    color: #555;
    margin-bottom: 20px;
  }

  .email-link {
    font-size: 16px;
    font-weight: 600;
    color: #E9560D;
    text-decoration: none;
  }
  .email-link:hover { text-decoration: underline; }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .contact-form input,
  .contact-form textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #ddd;
    border-radius: 6px;
    font-family: "Poppins", sans-serif;
    font-size: 15px;
    color: #333F48;
    box-sizing: border-box;
    background: #fff;
    transition: border-color 0.2s;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: #333F48;
  }

  .contact-form textarea { resize: vertical; }
  .contact-form .btn { align-self: flex-start; }

  /* ─── RESPONSIVE ─────────────────────────── */
  @media (max-width: 960px) {
    .traction-grid { grid-template-columns: repeat(2, 1fr); }
    .founders-grid { grid-template-columns: 1fr; }
    .contact-grid  { grid-template-columns: 1fr; gap: 48px; }
  }

  @media (max-width: 768px) {
    .two-col {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .two-col h2 { font-size: 36px; }
    .body-col p  { font-size: 16px; }
    .t-figure    { font-size: 22px; }
  }

  @media (max-width: 480px) {
    .traction-grid { grid-template-columns: 1fr; }
  }
</style>
