---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
---

<BaseLayout>

  <!-- Migration notice -->
  <div class="migration-banner">
    This site is moving to
    <a href="https://camentis.ai" target="_blank" rel="noopener">camentis.ai</a>
    in September 2026
  </div>

  <Header />

  <main>

    <Hero height="74vh" />

    <!-- ═══════════════════════════════════════
         WHAT WE DO (hexagon-framed flowline visual)
    ══════════════════════════════════════════ -->
    <section class="platform" id="platform">
      <div class="container split">

        <div class="split-copy">
          <p class="eyebrow">Platform</p>
          <h2>One consistent view of productivity</h2>
          <p>
            Multi-source construction data exists on every project, but it
            sits in disconnected silos: planning tools, site diaries,
            delivery records, and visual capture systems, with no
            integration layer connecting them. By the time a slowdown
            appears in the weekly report, the window to intervene has
            closed.
          </p>
          <p>
            Camentis connects those streams into one standardised view:
            planned-versus-actual comparisons, production rates, and flow
            and variability indicators, updated in near real time rather
            than after the fact.
          </p>
          <a href="https://app.camentis.ai" target="_blank" rel="noopener" class="link-arrow">
            See the platform ↗
          </a>
        </div>

        <div class="split-visual">
          <div class="hex-frame">
            <svg viewBox="0 0 300 300" class="flowline-art" role="img" aria-label="Flowline diagram illustrating planned versus actual construction progress">
              <rect width="300" height="300" fill="#EFF1F2" />
              <!-- planned lines -->
              <line x1="20" y1="240" x2="280" y2="60" stroke="#DADFE2" stroke-width="3" />
              <line x1="20" y1="270" x2="280" y2="110" stroke="#DADFE2" stroke-width="3" />
              <!-- actual, with a stall + recovery kink -->
              <polyline points="20,220 110,150 150,150 150,120 280,40" fill="none" stroke="#00A4B1" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
              <polyline points="20,255 130,175 168,175 168,150 280,95" fill="none" stroke="#002657" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
              <circle cx="150" cy="150" r="6" fill="#E5E798" stroke="#002657" stroke-width="1.5" />
            </svg>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════
         RESEARCH FOUNDATION (dark panel, ring gauge)
    ══════════════════════════════════════════ -->
    <section class="research">
      <div class="container research-body">

        <div class="split-copy" id="about">
          <p class="eyebrow">Research foundation</p>
          <h2 class="light">Five years of empirical research, University of Cambridge</h2>
          <p class="light-body">
            Camentis is built on empirical research at the Laing O'Rourke
            Centre for Construction Engineering and Technology, University of
            Cambridge, and validated through pilot deployments with Tier 1
            and Tier 2 UK contractors. The core technology is proven; we are
            actively engaging customers and partners to take it into
            production.
          </p>
          <p class="light-body">
            The approach has been validated across <strong>25+ projects</strong>
            with major UK contractors including Mace, Skanska, and Morrisroe,
            and recognised with <strong>two wins at the Industrialised Construction Awards 2025</strong>
            (Best Collaborative Project and Winner of Winners), plus a
            shortlisting for Digital Innovation.
          </p>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════
         FOUNDERS
    ══════════════════════════════════════════ -->
    <section class="founders">
      <div class="container">
        <h2 class="section-heading">Meet the team</h2>
        <div class="founders-grid">

          <div class="founder-card">
            <h3>Dr Ashan Asmone</h3>
            <span class="role">Research Associate, University of
              Cambridge</span>
            <p>
              15+ years
              across construction delivery, facilities management, and built
              environment research.
            </p>
            <a
              href="https://www.linkedin.com/in/ashan-asmone/"
              target="_blank"
              rel="noopener"
              class="linkedin-link"
            >
              LinkedIn ↗
            </a>
          </div>

          <div class="founder-card">
            <h3>Dr Danny Murguia</h3>
            <span class="role">Assistant Research Professor, University of
              Cambridge</span>
            <p>
              20 years of construction engineering experience.
              Leads digital automation research at the Laing O'Rourke Centre for
              Construction Engineering and Technology.
            </p>
            <a
              href="https://www.linkedin.com/in/dannymurguia/"
              target="_blank"
              rel="noopener"
              class="linkedin-link"
            >
              LinkedIn ↗
            </a>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         CONTACT
    ══════════════════════════════════════════ -->
    <section class="contact" id="contact">
      <div class="container contact-grid">

        <div class="contact-intro">
          <p class="eyebrow">Contact</p>
          <h2>Work with us</h2>
          <p>
            We are onboarding pilot partners for 2026–2027.<br>If you are a 
            Tier 1 or Tier 2 contractor in building or infrastructure sector, and want to
            explore what consistent productivity measurement looks like on
            your project, get in touch.
          </p>
          <!--
          <a href="mailto:info@camconiq.com" class="email-link">
            info@camconiq.com
          </a>
          -->
        </div>

        <!--
          FORM: uses Formspree for static-site email delivery.
          Endpoint connected: https://formspree.io/f/xkoleynp
        -->
        <form
          class="contact-form"
          action="https://formspree.io/f/xkoleynp"
          method="POST"
        >
          <input type="text" name="name" placeholder="Name" required />
          <input type="email" name="email" placeholder="Email" required />
          <textarea name="message" placeholder="Message" rows="5" required></textarea>
          <button type="submit" class="btn btn-primary">Send message</button>
        </form>

      </div>
    </section>

  </main>

  <Footer />

</BaseLayout>

<style>
  /* ─── MIGRATION BANNER ───────────────────── */
  .migration-banner {
    background: var(--light-grey);
    border-bottom: 1px solid var(--cool-grey);
    text-align: center;
    padding: 9px 24px;
    font-size: 13px;
    color: var(--slate);
    font-family: var(--font-body);
  }
  .migration-banner a {
    color: var(--teal-dark);
    font-weight: 600;
    text-decoration: none;
  }
  .migration-banner a:hover { text-decoration: underline; }

  /* ─── SPLIT LAYOUT (shared: platform + research) ─ */
  .split {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 64px;
    align-items: center;
  }

  .platform {
    padding: var(--section-pad) 0;
    background: var(--white);
  }

  .split-copy h2 {
    font-size: 38px;
    font-weight: 600;
    margin-bottom: 22px;
  }

  .split-copy p {
    font-size: 17px;
    line-height: 1.75;
    color: var(--slate);
    margin-bottom: 18px;
  }

  .link-arrow {
    display: inline-block;
    margin-top: 6px;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--teal-dark);
  }
  .link-arrow:hover { color: var(--navy); }

  .hex-frame {
    aspect-ratio: 1.05 / 1;
    clip-path: polygon(25% 0%, 75% 0%, 100% 50%, 75% 100%, 25% 100%, 0% 50%);
    background: var(--light-grey);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .flowline-art { width: 100%; height: 100%; }

  /* ─── RESEARCH (dark panel) ──────────────── */
  .research {
    padding: var(--section-pad) 0;
    background: var(--navy);
  }

  .research .light { color: var(--white); }
  .research .light-body { color: var(--cool-grey); }
  .research .eyebrow { color: var(--sky); }

  .research-body {
    max-width: 700px;
  }

  /* ─── FOUNDERS ───────────────────────────── */
  .founders {
    background: var(--light-grey);
    padding: var(--section-pad) 0;
  }

  .section-heading {
    font-size: 34px;
    font-weight: 600;
    margin: 0 0 44px 0;
  }

  .founders-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }

  .founder-card {
    background: var(--white);
    border: 1px solid var(--cool-grey);
    border-radius: 6px;
    padding: 34px;
    display: flex;
    flex-direction: column;
  }

  .founder-card h3 {
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 6px 0;
  }

  .role {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 600;
    color: var(--teal-dark);
    text-transform: uppercase;
    letter-spacing: 0.09em;
    margin-bottom: 18px;
  }

  .founder-card p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--slate);
    margin-bottom: 12px;
    flex-grow: 1;
  }

  .linkedin-link {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--navy);
    margin-top: 12px;
    transition: color 0.2s;
  }
  .linkedin-link:hover { color: var(--teal-dark); }

  /* ─── CONTACT ────────────────────────────── */
  .contact {
    padding: var(--section-pad) 0;
    background: var(--white);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: start;
  }

  .contact-intro h2 {
    font-size: 34px;
    font-weight: 600;
    margin: 0 0 20px 0;
  }

  .contact-intro p {
    font-size: 16px;
    line-height: 1.75;
    color: var(--slate);
    margin-bottom: 20px;
  }

  .email-link {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: var(--teal-dark);
  }
  .email-link:hover { text-decoration: underline; }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .contact-form input,
  .contact-form textarea {
    width: 100%;
    padding: 13px 16px;
    border: 1px solid var(--cool-grey);
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 15px;
    color: var(--slate);
    box-sizing: border-box;
    background: var(--white);
    transition: border-color 0.2s;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--teal);
  }

  .contact-form textarea { resize: vertical; }
  .contact-form .btn { align-self: flex-start; margin-top: 4px; }

  /* ─── RESPONSIVE ─────────────────────────── */
  @media (max-width: 960px) {
    .founders-grid { grid-template-columns: 1fr; }
    .contact-grid  { grid-template-columns: 1fr; gap: 48px; }
    .split {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hex-frame { max-width: 340px; margin: 0 auto; }
  }
</style>
