---
const { height = "72vh" } = Astro.props;
---

<section class="hero" style={`min-height: ${height}`}>

  <!-- Brand gradient: echoes the diagonal streak treatment on the
       Camentis style guide cover, built from the core + accent palette -->
  <svg class="hero-bg" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <linearGradient id="streak1" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#00A4B1" stop-opacity="0" />
        <stop offset="50%" stop-color="#00A4B1" stop-opacity="0.55" />
        <stop offset="100%" stop-color="#8AD4F5" stop-opacity="0" />
      </linearGradient>
      <linearGradient id="streak2" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#8AD4F5" stop-opacity="0" />
        <stop offset="50%" stop-color="#8AD4F5" stop-opacity="0.4" />
        <stop offset="100%" stop-color="#E5E798" stop-opacity="0" />
      </linearGradient>
      <linearGradient id="streak3" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#E5E798" stop-opacity="0" />
        <stop offset="50%" stop-color="#E5E798" stop-opacity="0.25" />
        <stop offset="100%" stop-color="#00A4B1" stop-opacity="0" />
      </linearGradient>
      <filter id="soften" x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="38" />
      </filter>
    </defs>
    <rect width="1200" height="800" fill="#002657" />
    <rect width="1200" height="800" fill="#001739" opacity="0.4" />
    <g filter="url(#soften)">
      <rect x="-300" y="120" width="1800" height="90" fill="url(#streak1)" transform="rotate(-16 600 400)" />
      <rect x="-300" y="320" width="1800" height="70" fill="url(#streak2)" transform="rotate(-16 600 400)" />
      <rect x="-300" y="520" width="1800" height="60" fill="url(#streak3)" transform="rotate(-16 600 400)" />
    </g>
  </svg>

  <div class="container hero-content">
    <p class="eyebrow eyebrow-light">Construction productivity intelligence</p>
    <h1>Building the future of construction<br class="lb" /> with data&#8209;driven intelligence</h1>
    <p class="sub">
      Camentis integrates fragmented site data, including
      <span class="accent">labour, delivery, IoT, progress, and visual capture</span>,
      into one consistent, near-real-time view of productivity.
      Measure. Benchmark. Improve.
    </p>
    <div class="cta-row">
      <a href="https://camentis.ai" target="_blank" rel="noopener" class="btn btn-primary">
        Open platform ↗
      </a>
      <a href="#contact" class="btn btn-outline">Get in touch</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    color: var(--white);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding: 90px 32px;
    max-width: 780px;
  }

  .eyebrow-light { color: var(--sky); }

  .hero h1 {
    color: var(--white);
    font-size: 52px;
    font-weight: 600;
    line-height: 1.12;
    margin-bottom: 26px;
  }

  .hero .sub {
    font-size: 18px;
    line-height: 1.7;
    color: var(--cool-grey);
    max-width: 600px;
    margin-bottom: 36px;
  }

  .hero .sub .accent {
    color: var(--yellow);
  }

  .cta-row {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero h1 { font-size: 36px; }
    .hero .sub { font-size: 16px; }
    .lb { display: none; }
  }
</style>
