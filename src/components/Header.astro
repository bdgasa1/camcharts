---
// No page links — single landing page. Nav: logo + platform button + contact anchor.
---

<header class="header">
  <div class="container">

    <a href="/" class="logo">
      <img src="/logo.svg" alt="Camentis" />
    </a>

    <button id="hamburger" class="hamburger" aria-label="Toggle menu">☰</button>

    <nav id="nav" class="nav">
      <ul class="menu">
        <li><a href="/#contact" class="contact-link">Contact</a></li>
        <li>
          <a
            href="https://camentis.ai"
            target="_blank"
            rel="noopener"
            class="platform-btn"
          >
            Open platform ↗
          </a>
        </li>
      </ul>
    </nav>

  </div>
</header>

<style>
  .header {
    width: 100%;
    background: #fff;
    border-bottom: 1px solid #eee;
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo img {
    height: 50px;
    width: auto;
    display: block;
  }

  .nav { display: block; }

  .menu {
    display: flex;
    list-style: none;
    gap: 24px;
    margin: 0;
    padding: 0;
    align-items: center;
  }

  .menu li a {
    text-decoration: none;
    font-weight: 500;
    color: #333F48;
    font-family: "Poppins", sans-serif;
    transition: color 0.25s ease;
  }

  .menu li a:hover { color: #E9560D; }

  /* "Open platform" button */
  .platform-btn {
    display: inline-block;
    padding: 10px 22px;
    background: #333F48;
    color: #fff !important;
    border-radius: 6px;
    font-weight: 600 !important;
    transition: background 0.2s ease;
  }

  .platform-btn:hover {
    background: #E9560D !important;
    color: #fff !important;
  }

  /* Hamburger — hidden on desktop */
  .hamburger {
    display: none;
    font-size: 28px;
    background: none;
    border: none;
    cursor: pointer;
    line-height: 1;
    padding: 4px;
    color: #333F48;
  }

  @media (max-width: 768px) {
    .hamburger { display: block; z-index: 100; }

    .nav {
      position: absolute;
      left: 0;
      top: 83px;
      width: 100%;
      background: #fff;
      overflow: hidden;
      max-height: 0;
      opacity: 0;
      border-bottom: 1px solid #eee;
      transition: max-height 0.35s ease, opacity 0.25s ease;
    }

    .nav.open { max-height: 160px; opacity: 1; }

    .menu {
      flex-direction: column;
      padding: 16px 24px;
      gap: 16px;
      align-items: flex-start;
    }
  }
</style>

<script>
  const btn = document.getElementById("hamburger");
  const nav = document.getElementById("nav");

  btn?.addEventListener("click", () => {
    nav.classList.toggle("open");
    btn.textContent = nav.classList.contains("open") ? "×" : "☰";
  });

  // Close nav when a link is clicked (mobile)
  nav?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      nav.classList.remove("open");
      btn.textContent = "☰";
    });
  });
</script>
